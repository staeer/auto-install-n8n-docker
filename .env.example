# Installer / stack version
STACK_VERSION=1.3.1

# Fixed image versions
N8N_IMAGE=n8nio/n8n:2.13.0
POSTGRES_IMAGE=postgres:16-alpine

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=
GENERIC_TIMEZONE=UTC
TZ=UTC

# Installation path
INSTALL_DIR=/opt/n8n

# External access
# Domain + reverse proxy example:
# N8N_HOST=n8n.example.com
# N8N_PROTOCOL=https
# WEBHOOK_URL=https://n8n.example.com/
#
# Direct access by IP example:
# N8N_HOST=192.168.1.10
# N8N_PROTOCOL=http
# WEBHOOK_URL=http://192.168.1.10:5678/
N8N_HOST=localhost
N8N_PROTOCOL=http
WEBHOOK_URL=
N8N_SECURE_COOKIE=true
