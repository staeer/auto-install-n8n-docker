# ═══════════════════════════════════════════════════
#  Конфигурация: Docker + n8n + PostgreSQL
#  Скопируйте этот файл рядом с install.sh
#  Пустые значения — будут сгенерированы автоматически
# ═══════════════════════════════════════════════════

# ── PostgreSQL ──────────────────────────────────────
POSTGRES_USER=n8n
POSTGRES_PASSWORD=         # оставьте пустым — сгенерируется автоматически
POSTGRES_DB=n8n

# ── n8n ─────────────────────────────────────────────
N8N_PORT=5678
N8N_ENCRYPTION_KEY=        # оставьте пустым — сгенерируется автоматически

# Ваш домен или IP (например: example.com или 192.168.1.10)
N8N_HOST=localhost
N8N_PROTOCOL=http          # http или https

# ── Установка ───────────────────────────────────────
INSTALL_DIR=/opt/n8n
