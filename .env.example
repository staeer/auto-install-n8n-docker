# Copy this file to .env and edit values if needed.
# Empty POSTGRES_PASSWORD or N8N_ENCRYPTION_KEY means: generate automatically during install.

# Stack versions
STACK_VERSION=1.1.0
N8N_IMAGE=n8nio/n8n:2.13.0
POSTGRES_IMAGE=postgres:16-alpine

# PostgreSQL
POSTGRES_USER=n8n
POSTGRES_PASSWORD=
POSTGRES_DB=n8n

# n8n
N8N_PORT=5678
N8N_ENCRYPTION_KEY=
GENERIC_TIMEZONE=UTC

# External access
# Use the public domain or IP that users will open in browser.
N8N_HOST=localhost
# Use http for direct access, https when behind reverse proxy with TLS.
N8N_PROTOCOL=http
# Full external base URL. Examples:
# http://192.168.1.10:5678/
# https://n8n.example.com/
WEBHOOK_URL=

# Install path
INSTALL_DIR=/opt/n8n
